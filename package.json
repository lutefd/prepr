{
  "name": "prepr",
  "version": "0.1.0",
  "description": "Local-first branch review bundles with Codex findings and a Svelte diff viewer.",
  "type": "module",
  "bin": {
    "prepr": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "ui/dist"
  ],
  "scripts": {
    "build": "npm run build:backend && npm run build:ui",
    "build:backend": "tsc -p tsconfig.json",
    "build:ui": "vite build --config ui/vite.config.ts",
    "bundle": "node scripts/bundle.mjs",
    "install:local": "node scripts/install-local.mjs",
    "dev:ui": "vite --config ui/vite.config.ts",
    "test": "node --test --import tsx test/**/*.test.ts",
    "test:native": "node --experimental-strip-types --no-warnings --loader ./test/ts-loader.mjs --test test/**/*.test.ts",
    "prepack": "npm run build"
  },
  "dependencies": {
    "@lucide/svelte": "^1.21.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "svelte": "^5.0.0",
    "vite": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20.11"
  }
}
